    [ "led_green:K", "esp:GND.2","black",[] ],

    [ "led_red:A",   "r2:1",    "red",   [] ],
    [ "r2:2",   "esp:D4",       "red",   [] ],
    [ "led_red:K",   "esp:GND.3","black", [] ],

    [ "led_blue:A",  "r3:1",    "blue",  [] ],
    [ "r3:2",   "esp:D5",       "blue",  [] ],
    [ "led_blue:K",  "esp:GND.4","black", [] ]
